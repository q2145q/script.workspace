generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH TABLES (managed by Better Auth — do not rename fields)
// ============================================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  betaApproved  Boolean   @default(false)

  sessions Session[]
  accounts Account[]

  // Application relations
  ownedProjects  Project[]       @relation("ProjectOwner")
  projectMembers ProjectMember[]
  commentThreads CommentThread[] @relation("ThreadCreator")
  commentMessages CommentMessage[] @relation("MessageAuthor")
  suggestions    Suggestion[]    @relation("SuggestionCreator")
  profile        UserProfile?
  apiUsageLogs   ApiUsageLog[]

  @@unique([email])
  @@map("user")
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  lastName        String   @default("")
  position        String   @default("Writer")
  company         String?
  defaultLanguage String   @default("en")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ============================================================
// APPLICATION TABLES
// ============================================================

enum ProjectRole {
  OWNER
  EDITOR
  COMMENTER
  VIEWER
}

enum ProjectType {
  FEATURE_FILM
  TV_SERIES
  SHORT_FILM
  OTHER
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  UNDER_REVIEW
  FINAL
  ARCHIVED
}

model Project {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        ProjectType   @default(FEATURE_FILM)
  status      ProjectStatus @default(DRAFT)
  language    String        @default("en")
  ownerId     String
  isPrivate   Boolean       @default(true)
  preferredProvider String?
  preferredModel    String?
  logline         String?   @db.Text
  synopsis        String?   @db.Text
  knowledgeGraph  Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  owner        User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      ProjectMember[]
  documents    Document[]
  aiProviders  AIProvider[]
  chatMessages ChatMessage[]
  bible        ProjectBible?
  contextPins  ContextPin[]
  ragChunks    RAGChunk[]
  episodes     Episode[]
  characters   Character[]
  locations    Location[]
  terms        Term[]
  activityLogs ActivityLog[]
  notes        ProjectNote[]

  @@index([ownerId])
  @@map("project")
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_member")
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  title     String   @default("Untitled")
  content   Json     @default("{}")
  yjsState  Bytes?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commentThreads CommentThread[]
  suggestions    Suggestion[]
  drafts         Draft[]
  episode        Episode?
  activityLogs   ActivityLog[]

  @@index([projectId])
  @@map("document")
}

model CommentThread {
  id          String   @id @default(cuid())
  documentId  String
  anchorFrom  Int
  anchorTo    Int
  resolved    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document  Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User             @relation("ThreadCreator", fields: [createdById], references: [id])
  messages  CommentMessage[]

  @@index([documentId])
  @@map("comment_thread")
}

model CommentMessage {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  thread CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User          @relation("MessageAuthor", fields: [authorId], references: [id])

  @@index([threadId])
  @@map("comment_message")
}

// ============================================================
// AI + SUGGESTION TABLES
// ============================================================

enum SuggestionStatus {
  PENDING
  APPLIED
  REJECTED
  UNDONE
}

model AIProvider {
  id        String   @id @default(cuid())
  projectId String
  provider  String   // "openai" | "anthropic"
  apiKeyEnc String   // encrypted API key (AES-256-GCM)
  model     String   @default("gpt-4o")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
  @@index([projectId])
  @@map("ai_provider")
}

model Suggestion {
  id            String           @id @default(cuid())
  documentId    String
  createdById   String
  instruction   String
  status        SuggestionStatus @default(PENDING)
  operations    Json             // Array<PatchOperation>
  selectedText  String
  selectionFrom Int
  selectionTo   Int
  explanation   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User     @relation("SuggestionCreator", fields: [createdById], references: [id])

  @@index([documentId])
  @@index([documentId, status])
  @@map("suggestion")
}

// ============================================================
// CHAT + BIBLE + CONTEXT TABLES
// ============================================================

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum ContextPinType {
  TEXT
  COMMENT
  CUSTOM
}

model ChatMessage {
  id        String          @id @default(cuid())
  projectId String
  userId    String
  role      ChatMessageRole
  content   String          @db.Text
  createdAt DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("chat_message")
}

model ProjectBible {
  id        String   @id @default(cuid())
  projectId String   @unique
  content   Json     @default("{}")
  yjsState  Bytes?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_bible")
}

model ContextPin {
  id        String         @id @default(cuid())
  projectId String
  userId    String
  type      ContextPinType @default(TEXT)
  content   String         @db.Text
  label     String?
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@map("context_pin")
}

model RAGChunk {
  id         String   @id @default(cuid())
  projectId  String
  sourceType String
  sourceId   String
  content    String   @db.Text
  embedding  Bytes?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("rag_chunk")
}

// ============================================================
// DRAFTS + EPISODES + ENTITIES (Phase 8)
// ============================================================

model Draft {
  id         String   @id @default(cuid())
  documentId String
  name       String?
  content    Json
  number     Int
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, number])
  @@map("draft")
}

model Episode {
  id         String   @id @default(cuid())
  projectId  String
  title      String
  number     Int
  documentId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([projectId, number])
  @@map("episode")
}

model Character {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?  @db.Text
  traits      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("character")
}

model Location {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("location")
}

model Term {
  id         String   @id @default(cuid())
  projectId  String
  term       String
  definition String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("term")
}

// ============================================================
// NOTES
// ============================================================

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  title     String   @default("Untitled Note")
  content   Json     @default("{}")
  yjsState  Bytes?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_note")
}

// ============================================================
// ACTIVITY LOG
// ============================================================

model ActivityLog {
  id         String   @id @default(cuid())
  projectId  String
  documentId String?
  userId     String
  action     String
  details    Json?
  createdAt  DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("activity_log")
}

// ============================================================
// ADMIN + GLOBAL CONFIGURATION
// ============================================================

model GlobalApiKey {
  id        String   @id @default(cuid())
  provider  String   @unique // "deepseek" | "anthropic" | "openai" | "gemini" | "yandex" | "grok"
  apiKeyEnc String            // encrypted (AES-256-GCM)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("global_api_key")
}

model GlobalModelConfig {
  id                   String   @id @default(cuid())
  provider             String
  modelId              String
  modelLabel           String
  isEnabled            Boolean  @default(true)
  costInputPerMillion  Float    @default(0)
  costOutputPerMillion Float    @default(0)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([provider, modelId])
  @@map("global_model_config")
}

model ApiUsageLog {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  provider   String
  model      String
  feature    String   // "chat" | "rewrite" | "format"
  tokensIn   Int
  tokensOut  Int
  durationMs Int?
  costUsd    Float?
  keySource  String   @default("global") // "global" | "user"
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@index([createdAt])
  @@map("api_usage_log")
}
